# Database
DATABASE_URL=sqlite:///./superowl.db
# For production: postgresql://user:pass@host:5432/superowl

# VAPI
VAPI_API_KEY=your_vapi_api_key_here
VAPI_OUTBOUND_PHONE=+12025551234
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_ASSISTANT_ID=your_base_assistant_id
VAPI_OWNER_ASSISTANT_ID=your_owner_pa_assistant_id
VAPI_WEBHOOK_URL=https://your-ngrok.ngrok-free.app/vapi-webhook

# Nango
NANGO_SECRET_KEY=your_nango_secret_key
NANGO_BASE_URL=https://api.nango.dev
NANGO_INTEGRATION_ID=slack

# Groq
GROQ_API_KEY=your_groq_api_key

# Vobiz SIP
VOBIZ_SIP_DOMAIN=40942180.sip.vobiz.ai

# Slack (fallback if Nango not used for some operations)
SLACK_WEBHOOK_URL=

# Misc
FALLBACK_ON_NO_ANI_MATCH=false